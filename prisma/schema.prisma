generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum CheckInStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
}

enum VerificationVerdict {
  APPROVE
  FLAG
}

enum DisputeOutcome {
  PENALIZED
  DISMISSED
}

enum GroupVisibility {
  PRIVATE
  PUBLIC
}

enum GroupFocusType {
  GENERAL
  DSA
  DEVELOPMENT
  EXAM_PREP
  MACHINE_LEARNING
  CUSTOM
}

enum TaskPostingMode {
  ADMINS_ONLY
  ALL_MEMBERS
}

enum PenaltyMode {
  BURN
  POOL
}

enum UserRole {
  member
  admin
}

enum GroupRole {
  member
  admin
}

enum TaskCategory {
  DSA
  DEVELOPMENT
  REVISION
  INTERVIEW_PREP
  READING
  CUSTOM
}

enum TaskScope {
  PERSONAL
  GROUP
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationKind {
  PRE_DEADLINE_NUDGE
  FLAGGED_SUBMISSION
}

enum GroupMessageReactionKind {
  FIRE
  CLAP
  TARGET
  ROCKET
}

enum CheckInReactionKind {
  FIRE
  STRONG
  THINKING
  EYES
}

enum MilestoneBadgeKind {
  FIRST_COMPLETION
  STREAK_7
  ZERO_PENALTIES_MONTH
  EARLY_BIRD_10
  REACTIONS_50
}

enum RedemptionStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id                      String                  @id
  name                    String
  email                   String
  emailVerified           Boolean                 @default(false)
  image                   String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  role                    UserRole                @default(member)
  isBlocked               Boolean?
  penaltyCount            Int                     @default(0)
  sessions                Session[]
  checkInReactions        CheckInReaction[]
  milestoneBadges         MilestoneBadge[]
  confessionPosts         ConfessionPost[]
  confessionUpvotes       ConfessionUpvote[]
  accounts                Account[]
  groups                  UserGroup[]
  createdGroups           Group[]                 @relation("GroupCreator")
  tasks                   Task[]
  checkIns                CheckIn[]
  messages                GroupMessage[]
  submissionVerifications SubmissionVerification[]
  penaltyEvents           PenaltyEvent[]
  startFiles              StartFile[]
  endFiles                EndFile[]
  notificationLogs        NotificationLog[]
  taskTemplates           TaskTemplate[]          @relation("UserTaskTemplates")
  createdTaskTemplates    TaskTemplate[]          @relation("CreatedTaskTemplates")
  messageReactions        GroupMessageReaction[]
  createdAssignments      Assignment[]            @relation("AssignmentCreator")
  reviewedCheckIns        CheckIn[]               @relation("CheckInReviewer")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Group {
  id                String                  @id @default(cuid())
  name              String
  description       String?
  link              String?
  visibility        GroupVisibility         @default(PRIVATE)
  focusType         GroupFocusType          @default(GENERAL)
  taskPostingMode   TaskPostingMode         @default(ALL_MEMBERS)
  penaltyMode       PenaltyMode             @default(BURN)
  inviteCode        String                  @unique
  inviteExpiresAt   DateTime
  maxMembers        Int                     @default(8)
  dailyPenalty      Int                     @default(10)
  createdById       String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  createdBy         User                    @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  users             UserGroup[]
  tasks             Task[]
  checkIns          CheckIn[]
  messages          GroupMessage[]
  penaltyEvents     PenaltyEvent[]
  startFiles        StartFile[]
  endFiles          EndFile[]
  notificationLogs  NotificationLog[]
  taskTemplates     TaskTemplate[]
  documents         GroupDocument[]
  hallOfFameEntries HallOfFame[]
  weeklyRecaps      WeeklyRecap[]
  confessionPosts   ConfessionPost[]
  redemptionTasks   RedemptionTask[]
  assignments       Assignment[]

  @@index([createdById])
  @@index([visibility, createdAt])
  @@map("group")
}

model UserGroup {
  userId          String
  groupId         String
  joinedAt        DateTime @default(now())
  role            GroupRole @default(member)
  points          Int      @default(0)
  streak          Int      @default(0)
  bestStreak      Int      @default(0)
  completions     Int      @default(0)
  misses          Int      @default(0)
  reputationScore Int      @default(60)
  inactivityStrikes Int    @default(0)
  lastCheckInAt  DateTime?
  earlyBirdCount  Int      @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group")
}

model Task {
  id          String      @id @default(cuid())
  title       String
  details     String?
  category    TaskCategory @default(CUSTOM)
  priority    TaskPriority @default(MEDIUM)
  targetMinutes Int?
  status      TaskStatus  @default(PENDING)
  dueAt       DateTime?
  day         DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?
  userId      String
  groupId     String
  broadcastKey String?
  checkInId      String?
  templateId     String?
  isChallengeMode Boolean  @default(false)
  earlyBirdCutoff DateTime?
  scope           TaskScope @default(PERSONAL)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn     CheckIn?    @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  template    TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, day])
  @@index([groupId, day])
  @@index([templateId, day], map: "task_template_day_idx")
  @@index([broadcastKey])
  @@map("task")
}

model CheckIn {
  id            String                  @id @default(cuid())
  day           DateTime
  reflection    String?
  proofText     String?
  proofLink     String?
  reviewNote    String?
  aiSummary     String?
  aiConfidence  Int?
  status        CheckInStatus           @default(PENDING)
  pointsAwarded Int                     @default(0)
  penaltyApplied Int                    @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  verifiedAt    DateTime?
  reviewedAt    DateTime?
  userId        String
  groupId       String
  assignmentQuestionId String?
  reviewedById  String?
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignmentQuestion AssignmentQuestion? @relation(fields: [assignmentQuestionId], references: [id], onDelete: SetNull)
  reviewedBy    User?                   @relation("CheckInReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  tasks         Task[]
  verifications SubmissionVerification[]
  penalties     PenaltyEvent[]
  startFiles    StartFile[]
  endFiles      EndFile[]
  notificationLogs NotificationLog[]
  reactions        CheckInReaction[]
  isEarlyBird      Boolean  @default(false)

  @@index([groupId, day])
  @@index([userId, day])
  @@index([assignmentQuestionId])
  @@map("check_in")
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  details     String?
  dueAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groupId     String
  createdById String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  questions   AssignmentQuestion[]

  @@index([groupId, createdAt])
  @@index([createdById])
  @@map("assignment")
}

model AssignmentQuestion {
  id            String   @id @default(cuid())
  prompt        String
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  checkIns      CheckIn[]

  @@index([assignmentId, order])
  @@map("assignment_question")
}

model SubmissionVerification {
  id             String              @id @default(cuid())
  verdict        VerificationVerdict
  note           String?
  disputeOutcome DisputeOutcome?
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  checkInId      String
  reviewerId     String
  checkIn        CheckIn             @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  reviewer       User                @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([checkInId])
  @@index([reviewerId])
  @@unique([checkInId, reviewerId])
  @@map("submission_verification")
}

model PenaltyEvent {
  id        String    @id @default(cuid())
  points    Int
  reason    String
  createdAt DateTime  @default(now())
  userId    String
  groupId   String
  checkInId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn   CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
  @@index([userId, createdAt])
  @@map("penalty_event")
}

model GroupMessage {
  id              String                 @id @default(cuid())
  content         String?
  imageUrl        String?
  imageName       String?
  imageStorageKey String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  userId          String
  groupId         String
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group           Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reactions       GroupMessageReaction[]

  @@index([groupId, createdAt])
  @@index([userId, createdAt])
  @@map("group_message")
}

model TaskTemplate {
  id            String      @id @default(cuid())
  title         String
  details       String?
  category      TaskCategory @default(CUSTOM)
  targetMinutes Int?
  scope         TaskScope   @default(PERSONAL)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String?
  groupId       String
  createdById   String
  user          User?       @relation("UserTaskTemplates", fields: [userId], references: [id], onDelete: Cascade)
  group         Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("CreatedTaskTemplates", fields: [createdById], references: [id], onDelete: Cascade)
  tasks         Task[]

  @@index([groupId, scope, isActive])
  @@index([userId, isActive])
  @@map("task_template")
}

model StartFile {
  id         String    @id @default(cuid())
  name       String
  url        String
  storageKey String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  groupId    String
  checkInId  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn    CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@map("start_file")
}

model EndFile {
  id         String    @id @default(cuid())
  name       String
  url        String
  storageKey String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  groupId    String
  checkInId  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn    CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@map("end_file")
}

model NotificationLog {
  id        String           @id @default(cuid())
  kind      NotificationKind
  dedupeKey String           @unique
  sentAt    DateTime         @default(now())
  taskDay   DateTime?
  userId    String
  groupId   String?
  checkInId String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  checkIn   CheckIn?         @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([groupId, sentAt])
  @@map("notification_log")
}

model GroupMessageReaction {
  id        String                   @id @default(cuid())
  kind      GroupMessageReactionKind
  createdAt DateTime                 @default(now())
  userId    String
  messageId String
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   GroupMessage             @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, kind])
  @@index([messageId])
  @@index([userId])
  @@map("group_message_reaction")
}

model CheckInReaction {
  id        String              @id @default(cuid())
  kind      CheckInReactionKind
  createdAt DateTime            @default(now())
  userId    String
  checkInId String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIn   CheckIn             @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@unique([checkInId, userId, kind])
  @@index([checkInId])
  @@index([userId])
  @@map("check_in_reaction")
}

model GroupDocument {
  id        String   @id @default(cuid())
  title     String
  content   String
  fileUrl   String?
  fileName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groupId   String
  authorId  String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("group_document")
}

model HallOfFame {
  id           String   @id @default(cuid())
  weekStart    DateTime
  topUserId    String
  bottomUserId String
  topName      String
  bottomName   String
  topStat      String
  bottomStat   String
  groupId      String
  createdAt    DateTime @default(now())
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, weekStart])
  @@index([groupId, weekStart])
  @@map("hall_of_fame")
}

model WeeklyRecap {
  id                  String   @id @default(cuid())
  weekStart           DateTime
  totalCompleted      Int      @default(0)
  mvpUserId           String?
  mvpName             String?
  penaltyLeaderUserId String?
  penaltyLeaderName   String?
  longestStreak       Int      @default(0)
  longestStreakName   String?
  memberStats         Json
  groupId             String
  createdAt           DateTime @default(now())
  group               Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, weekStart])
  @@index([groupId, weekStart])
  @@map("weekly_recap")
}

model MilestoneBadge {
  id        String             @id @default(cuid())
  kind      MilestoneBadgeKind
  earnedAt  DateTime           @default(now())
  userId    String
  groupId   String?
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, groupId])
  @@index([userId])
  @@map("milestone_badge")
}

model ConfessionPost {
  id        String             @id @default(cuid())
  content   String
  createdAt DateTime           @default(now())
  weekStart DateTime
  userId    String
  groupId   String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  upvotes   ConfessionUpvote[]

  @@unique([userId, groupId, weekStart])
  @@index([groupId, weekStart])
  @@map("confession_post")
}

model ConfessionUpvote {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  userId       String
  confessionId String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  confession   ConfessionPost @relation(fields: [confessionId], references: [id], onDelete: Cascade)

  @@unique([confessionId, userId])
  @@index([confessionId])
  @@map("confession_upvote")
}

model RedemptionTask {
  id          String           @id @default(cuid())
  title       String
  details     String?
  status      RedemptionStatus @default(PENDING)
  startFileUrl String?
  endFileUrl   String?
  reflection  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  targetUserId String
  groupId     String
  penaltyEventId String?
  group       Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, targetUserId])
  @@index([targetUserId])
  @@map("redemption_task")
}
